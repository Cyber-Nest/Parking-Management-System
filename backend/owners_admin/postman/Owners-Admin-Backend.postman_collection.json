    {
      "name": "Admin Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json?.data?.accessToken) pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  if (json?.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  if (json?.data?.admin?.id) pm.collectionVariables.set('adminId', json.data.admin.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
