{
  "name": "owners-admin",
  "version": "1.0.0",
  "description": "ParkSmart - Owners Admin Panel Backend (TypeScript + MySQL)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "kill-port 5000 && ts-node-dev --respawn --transpile-only src/index.ts",
    "seed": "node scripts/insert-admin.js",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "node scripts/migrate-db.js",
    "db:seed-sample": "node scripts/seed-sample-data.js",
    "db:seed-payment": "node node_modules/ts-node-dev/lib/bin.js --transpile-only --exit-child scripts/seed-payment-data.ts",
    "db:fix-zone-images": "node scripts/fix-zone-images.js",
    "db:seed-customer-plans": "node scripts/seed-customer-plans.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.3.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.7",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.13.0",
    "sequelize": "^6.37.7",
    "stripe": "^12.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.12.11",
    "@types/uuid": "^9.0.8",
    "kill-port": "^2.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
