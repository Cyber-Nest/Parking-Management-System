# ============================================================
# ParkSmart — Owners Admin Backend
# Database: LOCAL MySQL (sukanya connection / MySQL Workbench)
# ⚠️  NEVER commit this file to Git
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MySQL Connection ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=parksmart
DB_USER=root
DB_PASSWORD=sukanya

# ── JWT Secrets ──────────────────────────────────────────────
# Run TWICE to generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_GENERATED_SECRET_1
JWT_REFRESH_SECRET=REPLACE_WITH_GENERATED_SECRET_2
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email / SMTP (Gmail) ─────────────────────────────────────
# Google Account → Security → 2-Step Verification → App Passwords → Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM="ParkSmart <your_gmail@gmail.com>"

# ── App ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BCRYPT_SALT_ROUNDS=12